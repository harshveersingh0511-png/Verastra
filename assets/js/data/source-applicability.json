{
  "_meta": {
    "version": "1.0",
    "description": "Per-source applicability across the 12 canonical clusters. Consumed by aggregate/index.js (influenceWeight, sourceTier, salaryCaptureAllowed) and the dashboard coverage health calculation.",
    "schema": {
      "<source_id>": {
        "v1_status":          "live | light | future_slot",
        "source_tier":        "T1 (anchor) | T2 (corroborative) | T3 (auxiliary)",
        "salary_clue_capture": "true if salary fields are usable from this source",
        "influence_weight":   "{ <cluster_key>: [0.0..1.0] } — how much weight a posting from this source carries toward each cluster"
      }
    },
    "tier_definitions": {
      "T1": "Anchor source. Tight relevance, high signal-to-noise. Confidence boost.",
      "T2": "Corroborative source. Reliable but broader; needs T1 backing for HIGH tier.",
      "T3": "Auxiliary source. Light evidence only; never lifts a cell above MEDIUM alone."
    }
  },

