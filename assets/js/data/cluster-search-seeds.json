{
  "_meta": {
    "version": "1.0",
    "description": "Per-cluster search query seeds for broad adapters (naukri, indeed_in, foundit). Each cluster declares the search terms to fan out across its target cities. Schema: { <cluster_key>: { broad_queries: string[], city_keys: string[] } }. Underscore-prefixed keys (like _meta) are skipped at runtime by the adapters.",
    "guidance": "broad_queries: use natural-language search terms that match how jobs are typically titled on Indian job boards. Generic terms (\"finance manager\") cast a wider net than narrow ones (\"chartered accountant tax\"). city_keys: must match canonical city_keys from paths.js — adapters use CITIES[key].label to build the search URL."
  },

  "fin_acct_tax": {
    "broad_queries": [
      "chartered accountant",
      "finance manager",
      "financial planning analysis",
      "transfer pricing",
      "direct tax",
      "controller"
    ],
    "city_keys": ["mumbai", "bangalore", "delhi", "gurgaon", "hyderabad", "pune"]
  },

